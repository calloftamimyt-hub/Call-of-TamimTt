rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is authenticated via Firebase Auth
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the authenticated user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. App Settings & Config (Read-only for users, updated by Admins from Firebase Console)
    match /settings/{settingDoc} {
      allow read: if true;
      allow write: if false; 
    }
    match /banners/{bannerId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // 2. User Profiles
    match /users/{userId} {
      // Allow read without auth because the login screen searches 
      // by mobile number BEFORE the user is authenticated in Firebase Auth.
      // Also needed for Refer and Earn to look up referrers.
      allow read: if true;
      
      // ONLY the owner can create their own user document
      allow create: if isOwner(userId);
      
      // ONLY the owner can freely update their own user data.
      // We also allow other authenticated users to ONLY update the 'balance' field
      // (needed for adding referral bonuses).
      allow update: if isOwner(userId) || 
                   (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance']));
                   
      allow delete: if false;
    }
    
    // 3. Transactions & Requests (High Security - Strictly User Tied)
    match /withdrawals/{requestId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Prevent client apps from changing pending withdrawals
    }

    match /deposits/{depositId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /recharge_requests/{id} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // 4. External Account Service Integrations
    match /gmail_requests/{id} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
    match /facebook_requests/{id} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
    match /instagram_requests/{id} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
    match /whatsapp_requests/{id} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
    match /telegram_requests/{id} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // 5. Tasks, Jobs, Submissions
    match /task_posts/{taskId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    match /job_posts/{jobId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated(); // All auth users can read available jobs
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    match /submissions/{submissionId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Users can see their own submissions
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
    match /micro_jobs/{jobId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
    match /micro_job_submissions/{submissionId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // 6. Drive Packages
    match /drive_offers/{offerId} {
       allow read: if isAuthenticated();
       allow write: if false;
    }
    match /drive_orders/{orderId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // 7. General logs/notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // For system generation logs
      allow update, delete: if false;
    }
    match /history/{historyId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
    match /transactions/{transactionId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // 8. Secure Default Fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
